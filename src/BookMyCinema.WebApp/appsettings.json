{
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=.;Initial Catalog=BookMyCinemaDBDummy;Integrated Security=true;Encrypt=false; Trust Server Certificate=true"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.File",
            "Serilog.Sinks.Console",
            "Serilog.Sinks.Async"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.EntityFrameworkCore": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Async",
                "Args": {
                    "configure": [
                        {
                            "Name": "Console",
                            "Args": {
                                "outputTemplate": "[{Level:u3}] {Timestamp:dd-MM HH:mm:ss} || {MachineName} || {EnvironmentName} || {TraceId} || {SourceContext} || {Message}{NewLine}{Exception}{NewLine}"
                            }
                        }
                    ]
                }
            },
            {
                "Name": "Async",
                "Args": {
                    "configure": [
                        {
                            "Name": "File",
                            "Args": {
                                "path": "AppLogs/log-.log",
                                "restrictedToMinimumLevel": "Information",
                                "rollingInterval": "Day",
                                "rollOnFileSizeLimit": true,
                                "fileSizeLimitBytes": 10485760,
                                "retainedFileCountLimit": 60,
                                "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
                            }
                        }
                    ]
                }
            }
        ],
        "Enrich": [
            "WithMachineName",
            "WithEnvironmentName"
        ]
    },
    "AllowedHosts": "*"
}
